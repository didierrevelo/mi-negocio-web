generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String?
  password  String
  isAdmin   Boolean  @default(false)
  isActive  Boolean  @default(true)
  fcmToken  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ministryRoles     UserMinistryRole[]
  serviceTeam       ServiceTeam[]
  serviceSegments   ServiceSegment[]
  positionRequests  PositionRequest[]
  songs             Song[]
  songHistory       SongHistory[]
  files             File[]
  notifications     Notification[]
}

model Ministry {
  id        String   @id @default(uuid())
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roles            MinistryRole[]
  userMinistryRoles UserMinistryRole[]
  serviceSegments  ServiceSegment[]
  serviceTeam      ServiceTeam[]
  files            File[]
}

model MinistryRole {
  id          String   @id @default(uuid())
  name        String
  isActive    Boolean  @default(true)
  ministryId  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ministry         Ministry             @relation(fields: [ministryId], references: [id])
  userMinistryRoles UserMinistryRole[]
  serviceTeam      ServiceTeam[]
  positionRequests PositionRequest[]
}

model UserMinistryRole {
  id              String        @id @default(uuid())
  userId          String
  ministryId      String
  ministryRoleId  String
  isLeader        Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  ministry     Ministry      @relation(fields: [ministryId], references: [id])
  ministryRole MinistryRole  @relation(fields: [ministryRoleId], references: [id])

  @@unique([userId, ministryId, ministryRoleId])
}

model Service {
  id          String   @id @default(uuid())
  title       String
  date        DateTime
  time        String
  type        String   @default("worship")
  status      String   @default("planned")
  notes       String?
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator        User              @relation(fields: [createdBy], references: [id])
  segments       ServiceSegment[]
  team           ServiceTeam[]
  positionRequests PositionRequest[]
  songs          Song[]
  files          File[]
}

model ServiceSegment {
  id            String   @id @default(uuid())
  serviceId     String
  order         Int
  title         String
  durationMin   Int?
  notes         String?
  ministryId    String?
  responsibleId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  service      Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  ministry     Ministry?   @relation(fields: [ministryId], references: [id])
  responsible  User?       @relation(fields: [responsibleId], references: [id])
}

model ServiceTeam {
  id              String   @id @default(uuid())
  serviceId       String
  userId          String
  ministryId      String
  ministryRoleId  String
  status          String   @default("pending")
  note            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  service      Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id])
  ministry     Ministry     @relation(fields: [ministryId], references: [id])
  ministryRole MinistryRole @relation(fields: [ministryRoleId], references: [id])

  @@unique([serviceId, userId, ministryRoleId])
}

model PositionRequest {
  id              String   @id @default(uuid())
  serviceId       String
  ministryRoleId  String
  userId          String?
  status          String   @default("pending")
  note            String?
  requestedAt     DateTime @default(now())
  respondedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  service      Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  ministryRole MinistryRole @relation(fields: [ministryRoleId], references: [id])
  user         User?        @relation(fields: [userId], references: [id])
}

model Song {
  id            String   @id @default(uuid())
  serviceId     String
  order         Int
  title         String
  key           String?
  lyricsUrl     String?
  sheetMusicUrl String?
  youtubeLink   String?
  updatedById   String?
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  service    Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  updatedBy  User?       @relation(fields: [updatedById], references: [id])
  history    SongHistory[]
}

model SongHistory {
  id           String   @id @default(uuid())
  songId       String
  field        String
  oldValue     String?
  newValue     String?
  modifiedById String?
  createdAt    DateTime @default(now())

  song       Song @relation(fields: [songId], references: [id], onDelete: Cascade)
  modifiedBy User? @relation(fields: [modifiedById], references: [id])
}

model File {
  id           String   @id @default(uuid())
  serviceId    String
  ministryId   String?
  uploadedById String
  name         String
  type         String
  url          String
  size         Int
  version      Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  service    Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  ministry   Ministry?   @relation(fields: [ministryId], references: [id])
  uploadedBy User        @relation(fields: [uploadedById], references: [id])
}

model Notification {
  id          String   @id @default(uuid())
  userId      String
  type        String
  message     String
  referenceId String?
  referenceType String?
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
