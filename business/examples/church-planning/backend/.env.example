# ============================================
# VARIABLES DE ENTORNO - CHURCH PLANNING API
# ============================================
# Copia este archivo como .env y llena los valores
# NUNCA subir .env a Git

# ============================================
# DATABASE (Supabase - Gratis)
# ============================================
# Obtén la URL en: Supabase → Settings → Database → Connection string
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres"

# ============================================
# JWT (Seguridad)
# ============================================
# Genera un secret fuerte: openssl rand -base64 32
JWT_SECRET="[GENERATE-A-STRONG-SECRET-32-CHARS]"
JWT_EXPIRES_IN="7d"

# ============================================
# AWS S3 (Cloudflare R2 - Gratis)
# ============================================
# Obtén las credenciales en: Cloudflare → R2 → Manage R2 API Tokens
AWS_ACCESS_KEY_ID="[YOUR-R2-ACCESS-KEY]"
AWS_SECRET_ACCESS_KEY="[YOUR-R2-SECRET-KEY]"
AWS_REGION="auto"
S3_BUCKET_NAME="church-planning-files"

# ============================================
# FIREBASE (Push Notifications - Gratis)
# ============================================
# Obtén las credenciales en: Firebase → Project Settings → Service accounts
FIREBASE_PROJECT_ID="[YOUR-FIREBASE-PROJECT-ID]"
FIREBASE_PRIVATE_KEY="[YOUR-FIREBASE-PRIVATE-KEY]"
FIREBASE_CLIENT_EMAIL="[YOUR-FIREBASE-CLIENT-EMAIL]"

# ============================================
# SENTRY (Error Tracking - Gratis)
# ============================================
# Obtén el DSN en: Sentry → Project → Settings → Client Keys
SENTRY_DSN="[YOUR-SENTRY-DSN]"

# ============================================
# SERVER
# ============================================
PORT=3000
NODE_ENV=development
CORS_ORIGIN="*"

# ============================================
# PRODUCTION OVERRIDES (Railway)
# ============================================
# En Railway, estas variables se configuran en el dashboard
# NODE_ENV=production
# PORT=3000 (Railway asigna automáticamente)
